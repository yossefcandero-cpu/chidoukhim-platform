# Secret utilisé pour signer les cookies de session (obligatoire, generer une valeur aleatoire longue)
SESSION_SECRET=change-moi-en-une-longue-chaine-aleatoire

# --- Notifications (optionnel, sans ces cles les notifications sont simplement journalisees) ---
# Envoi de SMS (verification telephone, alertes) via un fournisseur type Twilio
SMS_PROVIDER_API_KEY=
# Envoi d'email via un fournisseur type Resend / Postmark
EMAIL_PROVIDER_API_KEY=
# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_TOKEN=

# --- IA (optionnel) ---
# Cle API Claude (Anthropic) pour la mise en forme en langage naturel des explications de compatibilite
ANTHROPIC_API_KEY=

# Compte administrateur initial cree par `npm run seed`
ADMIN_EMAIL=admin@chidoukhim.example
ADMIN_PASSWORD=change-moi-mot-de-passe-fort
